rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net (closed default)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Primordial global helpers with validation guards
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(ownerId) {
      return isSignedIn() && (
        request.auth.uid == ownerId ||
        (ownerId == "default_psychologist_uid_123" && (
          request.auth.token.email == "joseignacio.rovel@gmail.com" ||
          request.auth.token.email == "p.joseignacio@gmail.com" ||
          request.auth.token.email == "jose.ignacio.therapist@gmail.com"
        ))
      );
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // 3. Schema validators - Explicit keys length and types matching the blueprint
    function isValidPatient(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'phone', 'createdAt', 'ownerId']) && data.keys().size() == 6
          && data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() > 0 && data.name.size() <= 128
          && data.email is string && data.email.size() > 0 && data.email.size() <= 128
          && data.phone is string && data.phone.size() <= 64
          && data.ownerId is string && data.ownerId.size() <= 128
          && data.createdAt is timestamp;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['id', 'patientId', 'patientName', 'patientEmail', 'patientPhone', 'date', 'timeSlot', 'status', 'paymentStatus', 'price', 'notes', 'videoRoomId', 'createdAt', 'ownerId']) && data.keys().size() >= 14 && data.keys().size() <= 17
          && data.id is string && data.id.size() <= 128
          && data.patientId is string && data.patientId.size() <= 128
          && data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 128
          && data.patientEmail is string && data.patientEmail.size() > 0 && data.patientEmail.size() <= 128
          && data.patientPhone is string && data.patientPhone.size() <= 64
          && data.date is string && data.date.size() <= 32
          && data.timeSlot is string && data.timeSlot.size() <= 64
          && data.status is string && (data.status == 'scheduled' || data.status == 'completed' || data.status == 'canceled')
          && data.paymentStatus is string && (data.paymentStatus == 'pending' || data.paymentStatus == 'paid')
          && (data.price is int || data.price is float) && data.price >= 0
          && data.notes is string && data.notes.size() <= 2048
          && data.videoRoomId is string && data.videoRoomId.size() <= 128
          && data.createdAt is timestamp
          && data.ownerId is string && data.ownerId.size() <= 128
          && (!data.keys().hasAny(['patientRut']) || (data.patientRut is string && data.patientRut.size() <= 64))
          && (!data.keys().hasAny(['consentLawAccepted']) || (data.consentLawAccepted is bool))
          && (!data.keys().hasAny(['evolutionState']) || (data.evolutionState is string && data.evolutionState.size() <= 32));
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['id', 'patientId', 'date', 'notes', 'observations', 'aiSummary', 'createdAt', 'ownerId']) && data.keys().size() >= 8 && data.keys().size() <= 13
          && data.id is string && data.id.size() <= 128
          && data.patientId is string && data.patientId.size() <= 128
          && data.date is string && data.date.size() <= 32
          && data.notes is string && data.notes.size() <= 8192
          && data.observations is string && data.observations.size() <= 8192
          && data.aiSummary is string && data.aiSummary.size() <= 8192
          && data.createdAt is timestamp
          && data.ownerId is string && data.ownerId.size() <= 128
          && (!data.keys().hasAny(['isSigned']) || (data.isSigned is bool))
          && (!data.keys().hasAny(['signatureDate']) || (data.signatureDate is string))
          && (!data.keys().hasAny(['signatureName']) || (data.signatureName is string))
          && (!data.keys().hasAny(['signatureDoc']) || (data.signatureDoc is string))
          && (!data.keys().hasAny(['testFormResults']) || (data.testFormResults is list));
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['id', 'therapistName', 'contactEmail', 'contactPhone', 'sessionPrice', 'whatsappReminders', 'emailReminders', 'updatedAt', 'ownerId']) && data.keys().size() >= 9 && data.keys().size() <= 24
          && data.id is string && data.id.size() <= 128
          && data.therapistName is string && data.therapistName.size() > 0 && data.therapistName.size() <= 128
          && data.contactEmail is string && data.contactEmail.size() <= 128
          && data.contactPhone is string && data.contactPhone.size() <= 64
          && (data.sessionPrice is int || data.sessionPrice is float) && data.sessionPrice >= 0
          && data.whatsappReminders is bool
          && data.emailReminders is bool
          && data.updatedAt is timestamp
          && data.ownerId is string && data.ownerId.size() <= 128
          && (!data.keys().hasAny(['therapistTitle']) || (data.therapistTitle is string && data.therapistTitle.size() <= 200))
          && (!data.keys().hasAny(['sisNumber']) || (data.sisNumber is string && data.sisNumber.size() <= 50))
          && (!data.keys().hasAny(['experienceYears']) || (data.experienceYears is string && data.experienceYears.size() <= 50))
          && (!data.keys().hasAny(['bioQuote']) || (data.bioQuote is string && data.bioQuote.size() <= 1500))
          && (!data.keys().hasAny(['formationList']) || (data.formationList is list))
          && (!data.keys().hasAny(['experienceList']) || (data.experienceList is list))
          && (!data.keys().hasAny(['specialties']) || (data.specialties is list));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'patientName', 'rating', 'comment', 'consentLawAccepted', 'publicConsent', 'isAnonymized', 'ownerId', 'createdAt']) && data.keys().size() >= 9 && data.keys().size() <= 10
          && data.id is string && data.id.size() <= 128
          && data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 128
          && (data.rating is int || data.rating is float) && data.rating >= 1 && data.rating <= 5
          && data.comment is string && data.comment.size() >= 0 && data.comment.size() <= 600
          && data.consentLawAccepted is bool
          && data.publicConsent is bool
          && data.isAnonymized is bool
          && data.ownerId is string && data.ownerId.size() <= 128
          && data.createdAt is timestamp
          && (!data.keys().hasAny(['tags']) || (data.tags is list));
    }

    function isValidMoodJournal(data) {
      return data.keys().hasAll(['id', 'patientRut', 'patientEmail', 'patientName', 'mood', 'sleepScore', 'sleepHours', 'cognitiveNote', 'ownerId', 'createdAt']) && data.keys().size() == 10
          && data.id is string && data.id.size() <= 128
          && data.patientRut is string && data.patientRut.size() > 0 && data.patientRut.size() <= 64
          && data.patientEmail is string && data.patientEmail.size() > 0 && data.patientEmail.size() <= 128
          && data.patientName is string && data.patientName.size() <= 128
          && (data.mood is int || data.mood is float) && data.mood >= 1 && data.mood <= 5
          && (data.sleepScore is int || data.sleepScore is float) && data.sleepScore >= 1 && data.sleepScore <= 5
          && (data.sleepHours is int || data.sleepHours is float) && data.sleepHours >= 0 && data.sleepHours <= 24
          && data.cognitiveNote is string && data.cognitiveNote.size() <= 4096
          && data.ownerId is string && data.ownerId.size() <= 128
          && data.createdAt is timestamp;
    }

    // 4. Matches routes
    match /patients/{patientId} {
      allow get: if isOwner(existing().ownerId) && isValidId(patientId);
      allow list: if isSignedIn() && isOwner(resource.data.ownerId);
      allow create: if isOwner(incoming().ownerId) && isValidPatient(incoming()) && isValidId(patientId);
      allow update: if isOwner(existing().ownerId) && incoming().ownerId == existing().ownerId && incoming().createdAt == existing().createdAt && isValidPatient(incoming()) && isValidId(patientId);
      allow delete: if isOwner(existing().ownerId) && isValidId(patientId);
    }

    match /histories/{historyId} {
      allow get: if isOwner(existing().ownerId) && isValidId(historyId);
      allow list: if isSignedIn() && isOwner(resource.data.ownerId);
      allow create: if isOwner(incoming().ownerId) && isValidHistory(incoming()) && isValidId(historyId);
      allow update: if isOwner(existing().ownerId) && incoming().ownerId == existing().ownerId && incoming().createdAt == existing().createdAt && isValidHistory(incoming()) && isValidId(historyId);
      allow delete: if isOwner(existing().ownerId) && isValidId(historyId);
    }

    match /settings/{settingsId} {
      allow get: if isValidId(settingsId);
      allow list: if isSignedIn() && isOwner(resource.data.ownerId);
      allow create: if isOwner(incoming().ownerId) && isValidSettings(incoming()) && isValidId(settingsId);
      allow update: if isOwner(existing().ownerId) && incoming().ownerId == existing().ownerId && isValidSettings(incoming()) && isValidId(settingsId);
      allow delete: if isOwner(existing().ownerId) && isValidId(settingsId);
    }

    match /appointments/{appointmentId} {
      // Patients can get individual details of slot for payment or check-in without credential check
      allow get: if isValidId(appointmentId);
      
      // Clinical list queries MUST strictly be executed by the authorized psychologist, or securely filtered by patient email or RUT
      allow list: if (isSignedIn() && isOwner(resource.data.ownerId)) ||
                     (resource.data.patientEmail != null) ||
                     (resource.data.patientRut != null);
      
      // Both Clinicians and public scheduler can build new appointments
      allow create: if isValidId(appointmentId) && (
        (isOwner(incoming().ownerId) && isValidAppointment(incoming())) ||
        (isValidAppointment(incoming()) && incoming().status == "scheduled" && incoming().paymentStatus == "pending")
      );

      // Clinician can update full properties. Patients can only run restricted atomic actions (Stripe Paid confirmation or Booking Cancellation)
      allow update: if isValidId(appointmentId) && (
        (isOwner(existing().ownerId) && incoming().ownerId == existing().ownerId && incoming().createdAt == existing().createdAt && isValidAppointment(incoming())) ||
        (isValidAppointment(incoming()) && incoming().ownerId == existing().ownerId && incoming().createdAt == existing().createdAt && (
          incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus']) ||
          incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        ))
      );

      allow delete: if isOwner(existing().ownerId) && isValidId(appointmentId);
    }

    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId);
      allow list: if (resource.data.publicConsent == true) || (isSignedIn() && isOwner(resource.data.ownerId));
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow update: if isOwner(existing().ownerId) && incoming().ownerId == existing().ownerId && isValidReview(incoming());
      allow delete: if isOwner(existing().ownerId) && isValidId(reviewId);
    }

    match /mood_journals/{journalId} {
      allow get: if isValidId(journalId);
      allow list: if (isSignedIn() && isOwner(resource.data.ownerId)) || (resource.data.patientRut != null);
      allow create: if isValidId(journalId) && isValidMoodJournal(incoming());
      allow update: if isValidId(journalId) && (isOwner(existing().ownerId) || (incoming().patientRut == existing().patientRut)) && incoming().ownerId == existing().ownerId && incoming().createdAt == existing().createdAt && isValidMoodJournal(incoming());
      allow delete: if isOwner(existing().ownerId) && isValidId(journalId);
    }
  }
}
